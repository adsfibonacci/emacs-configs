\begin{MintedVerbatim}[commandchars=\\\{\}]
\PYG{c+c1}{;; Prevent Treemacs from trying to load magit\PYGZhy{}bookmark}
\PYG{p}{(}\PYG{n+nb}{with\PYGZhy{}eval\PYGZhy{}after\PYGZhy{}load}\PYG{+w}{ }\PYG{l+s+ss}{\PYGZsq{}treemacs\PYGZhy{}bookmarks}
\PYG{+w}{  }\PYG{p}{(}\PYG{n+nb}{define\PYGZhy{}minor\PYGZhy{}mode}\PYG{+w}{ }\PYG{n+nv}{treemacs\PYGZhy{}\PYGZhy{}dummy\PYGZhy{}magit\PYGZhy{}bookmark\PYGZhy{}mode}
\PYG{+w}{    }\PYG{l+s}{\PYGZdq{}Dummy mode to satisfy Treemacs bookmark requirement.\PYGZdq{}}\PYG{p}{))}

\PYG{p}{(}\PYG{n+nb}{provide}\PYG{+w}{ }\PYG{l+s+ss}{\PYGZsq{}magit\PYGZhy{}bookmark}\PYG{p}{)}\PYG{+w}{  }\PYG{c+c1}{;; pretend the feature exists}
\end{MintedVerbatim}
